# Authentication mode: "basic" (default) or "oauth"
# VITE_AUTH_MODE=basic

# OAuth settings (only used when VITE_AUTH_MODE=oauth)
# VITE_OAUTH_AUTHORITY=http://localhost:8888/realms/operaton
# VITE_OAUTH_CLIENT_ID=operaton-web-apps
# VITE_OAUTH_REDIRECT_URI=http://127.0.0.1:5173/

# URL of the runtime plugin manifest (JSON array of plugin packages).
# Defaults to /plugins/plugins.json served from the app origin. See
# docs/Plugin System.md.
# VITE_PLUGINS_URL=/plugins/plugins.json
