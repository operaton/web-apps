    "@testing-library/preact": "^3.2.4",
    "@vitest/ui": "^4.0.7",
    "eslint": "^9.39.5",
    "eslint-config-preact": "^2.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "happy-dom": "^20.0.10",
    "jsdom": "^29.0.0",
    "lint-staged": "^17.2.0",
    "pa11y": "^9.1.1",
    "simple-git-hooks": "^2.13.1",
    "vite": "^8.0.0",
    "vitest": "^4.0.7"
  }
