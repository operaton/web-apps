    "bpmn-js": "^18.21.0",
    "bpmn-moddle": "^10.0.0",
    "dmn-js": "^17.3.0",
    "dompurify": "^3.1.2",
    "htm": "^3.1.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^4.0.0",
    "preact": "^10.22.1",
    "preact-iso": "^2.6.3",
    "react-bpmn": "^0.2.0",
    "react-hotkeys-hook": "^5.3.3",
    "react-i18next": "^17.0.10"
  },
  "devDependencies": {
