  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx}": "eslint"
  },
  "dependencies": {
    "@bpmn-io/feelin": "^6.1.0",
