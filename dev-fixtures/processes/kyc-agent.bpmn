<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Defs_KycAgent" targetNamespace="http://operaton.org/examples" exporter="Camunda Modeler" exporterVersion="5.29.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.23.0">
  <message id="Msg_AddressCorrected" name="AddressCorrected" />
  <error id="Error_SanctionsUnavailable" name="SanctionsUnavailable" errorCode="SANCTIONS_UNAVAILABLE" />
  <process id="kyc-agent" name="KYC Agent (Operaton, agent-as-process)" isExecutable="true" camunda:historyTimeToLive="P30D">
    <startEvent id="start" name="KYC application received">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="fullName" label="Full name" type="string" defaultValue="Erika Mustermann">
            <camunda:validation>
              <camunda:constraint name="required" />
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="dateOfBirth" label="Date of birth (YYYY-MM-DD)" type="string" defaultValue="1985-04-12">
            <camunda:validation>
              <camunda:constraint name="required" />
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="address" label="Address" type="string" defaultValue="Musterstrasse 1, 55116 Mainz">
            <camunda:validation>
              <camunda:constraint name="required" />
            </camunda:validation>
          </camunda:formField>
        </camunda:formData>
      </extensionElements>
    </startEvent>
    <sequenceFlow id="f1" sourceRef="start" targetRef="loop_merge" />
    <exclusiveGateway id="loop_merge" name="" />
    <sequenceFlow id="f2" sourceRef="loop_merge" targetRef="agent_decide" />
    <serviceTask id="agent_decide" name="Agent: decide next action" camunda:type="external" camunda:topic="agent-decide" />
    <sequenceFlow id="f3" sourceRef="agent_decide" targetRef="policy_guard" />
    <businessRuleTask id="policy_guard" name="Policy guardrail (DMN)" camunda:resultVariable="policy" camunda:decisionRef="tool-policy" camunda:mapDecisionResult="singleResult" />
    <sequenceFlow id="f24" sourceRef="policy_guard" targetRef="gw_policy" />
    <exclusiveGateway id="gw_policy" name="Policy?" default="f25" />
    <sequenceFlow id="f25" sourceRef="gw_policy" targetRef="route" />
    <sequenceFlow id="f26" sourceRef="gw_policy" targetRef="deny_inject">
      <conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tFormalExpression">${policy.verdict == 'deny'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f27" sourceRef="gw_policy" targetRef="escalate">
      <conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tFormalExpression">${policy.verdict == 'require_human'}</conditionExpression>
    </sequenceFlow>
    <serviceTask id="deny_inject" name="Inject policy denial into context" camunda:type="external" camunda:topic="policy-denied" />
    <sequenceFlow id="f28" sourceRef="deny_inject" targetRef="loop_merge" />
    <exclusiveGateway id="route" name="Next action?" default="f10" />
    <sequenceFlow id="f4" sourceRef="route" targetRef="check_sanctions">
      <conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tFormalExpression">${nextAction == 'check_sanctions'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f5" sourceRef="route" targetRef="verify_address">
      <conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tFormalExpression">${nextAction == 'verify_address'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f6" sourceRef="route" targetRef="calculate_risk">
      <conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tFormalExpression">${nextAction == 'calculate_risk'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f7" sourceRef="route" targetRef="create_customer">
      <conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tFormalExpression">${nextAction == 'create_customer_record'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f8" sourceRef="route" targetRef="request_document">
      <conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tFormalExpression">${nextAction == 'request_document'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f9" sourceRef="route" targetRef="escalate">
      <conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tFormalExpression">${nextAction == 'escalate_to_human'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f10" sourceRef="route" targetRef="approve" />
    <serviceTask id="check_sanctions" name="Tool: check sanctions" camunda:type="external" camunda:topic="check-sanctions" />
    <boundaryEvent id="err_sanctions" name="service unavailable" attachedToRef="check_sanctions">
      <errorEventDefinition errorRef="Error_SanctionsUnavailable" />
    </boundaryEvent>
    <sequenceFlow id="f17" sourceRef="err_sanctions" targetRef="loop_merge" />
    <sequenceFlow id="f11" sourceRef="check_sanctions" targetRef="loop_merge" />
    <serviceTask id="verify_address" name="Tool: verify address" camunda:type="external" camunda:topic="verify-address" />
    <sequenceFlow id="f12" name="" sourceRef="verify_address" targetRef="loop_merge" />
    <serviceTask id="calculate_risk" name="Tool: calculate risk" camunda:type="external" camunda:topic="calculate-risk" />
    <sequenceFlow id="f13" sourceRef="calculate_risk" targetRef="loop_merge" />
    <serviceTask id="create_customer" name="Tool: create customer record" camunda:type="external" camunda:topic="create-customer-record" />
    <boundaryEvent id="comp_boundary" attachedToRef="create_customer">
      <compensateEventDefinition />
    </boundaryEvent>
    <serviceTask id="delete_customer" name="Compensate: delete customer record" isForCompensation="true" camunda:type="external" camunda:topic="delete-customer-record" />
    <sequenceFlow id="f14" sourceRef="create_customer" targetRef="loop_merge" />
    <userTask id="request_document" name="Clerk: provide requested document" camunda:candidateGroups="clerk">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="agentQuestion" label="The agent is requesting:" type="string">
            <camunda:properties>
              <camunda:property id="readonly" value="true" />
            </camunda:properties>
          </camunda:formField>
          <camunda:formField id="agentQuestionContext" label="Reason:" type="string">
            <camunda:properties>
              <camunda:property id="readonly" value="true" />
            </camunda:properties>
          </camunda:formField>
          <camunda:formField id="humanResponse" label="Your response (folded back into the case as the tool result):" type="string">
            <camunda:validation>
              <camunda:constraint name="required" />
            </camunda:validation>
          </camunda:formField>
        </camunda:formData>
      </extensionElements>
    </userTask>
    <sequenceFlow id="f15" sourceRef="request_document" targetRef="loop_merge" />
    <userTask id="escalate" name="Clerk: judgment call (near-match)" camunda:candidateGroups="clerk">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="agentQuestion" label="The agent is asking:" type="string">
            <camunda:properties>
              <camunda:property id="readonly" value="true" />
            </camunda:properties>
          </camunda:formField>
          <camunda:formField id="agentQuestionContext" label="Context:" type="string">
            <camunda:properties>
              <camunda:property id="readonly" value="true" />
            </camunda:properties>
          </camunda:formField>
          <camunda:formField id="humanResponse" label="Your judgment call (folded back into the case as the tool result):" type="string">
            <camunda:validation>
              <camunda:constraint name="required" />
            </camunda:validation>
          </camunda:formField>
        </camunda:formData>
      </extensionElements>
    </userTask>
    <sequenceFlow id="f16" sourceRef="escalate" targetRef="loop_merge" />
    <userTask id="approve" name="Approver: sign off KYC decision" camunda:formRef="kyc-approve-form" camunda:formRefBinding="deployment" camunda:candidateGroups="approver" />
    <sequenceFlow id="f18" sourceRef="approve" targetRef="approved_gw" />
    <exclusiveGateway id="approved_gw" name="Approved?" default="f20" />
    <sequenceFlow id="f19" sourceRef="approved_gw" targetRef="end_ok">
      <conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tFormalExpression">${approved}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f20" sourceRef="approved_gw" targetRef="compensate_throw" />
    <intermediateThrowEvent id="compensate_throw" name="undo side effects">
      <compensateEventDefinition />
    </intermediateThrowEvent>
    <sequenceFlow id="f21" sourceRef="compensate_throw" targetRef="end_rejected" />
    <endEvent id="end_ok" name="Customer onboarded" />
    <endEvent id="end_rejected" name="Rejected, side effects compensated" />
    <subProcess id="sub_correction" name="Mid-flight correction" triggeredByEvent="true">
      <startEvent id="msg_start" name="Address corrected" isInterrupting="false">
        <messageEventDefinition messageRef="Msg_AddressCorrected" />
      </startEvent>
      <sequenceFlow id="f22" sourceRef="msg_start" targetRef="inject_context" />
      <serviceTask id="inject_context" name="Inject correction into agent context" camunda:type="external" camunda:topic="inject-context" />
      <sequenceFlow id="f23" sourceRef="inject_context" targetRef="end_sub" />
      <endEvent id="end_sub" />
    </subProcess>
    <association id="assoc_comp" associationDirection="One" sourceRef="comp_boundary" targetRef="delete_customer" />
  </process>
  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="kyc-agent">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
