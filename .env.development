# .env.development
VITE_BACKEND=[{"name": "Operaton", "url": "http://localhost:8084"}, {"name": "Dev c7", "url": "http://localhost:8088", "c7_mode": true}]
VITE_HIDE_RELEASE_WARNING=true
VITE_AUTH_MODE=basic

# OAuth settings (activate by setting VITE_AUTH_MODE=oauth in .env.development.local)
VITE_OAUTH_AUTHORITY=http://localhost:8888/realms/operaton
VITE_OAUTH_CLIENT_ID=operaton-web-apps
VITE_OAUTH_REDIRECT_URI=http://127.0.0.1:5173/
